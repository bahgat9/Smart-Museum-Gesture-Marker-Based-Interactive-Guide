<UserControl x:Class="GestureGUI.Pages.LandingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="Transparent">

        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            
            <RowDefinition Height="*"/>
            
            <RowDefinition Height="Auto"/>
            
        </Grid.RowDefinitions>

        
        <TextBlock Text="Smart Museum"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"
                   Margin="0,30,0,10"
                   Grid.Row="0"/>

        
        <Canvas x:Name="PieCanvas"
                Width="400"
                Height="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Grid.Row="1"/>

        
        <Border Background="#AA1E1E1E"
                CornerRadius="15"
                Padding="20"
                Width="700"
                HorizontalAlignment="Center"
                Margin="0,10,0,20"
                Grid.Row="2">

            <StackPanel>

               
                <TextBlock Text="How to Use"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="0,0,0,10"
                           HorizontalAlignment="Center"/>

                
                <TextBlock TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="14"
                           LineHeight="22">

                    <Run Text="1. "/>
                    <Run Text="Use your index finger to move the cursor and pinch to select your option."/>
                    <LineBreak/><LineBreak/>

                    <Run Text="2. "/>
                    <Run Text="When in another page, perform a circle gesture to return to the main menu."/>
                    <LineBreak/><LineBreak/>

                    <Run Text="3. "/>
                    <Run Text="Connect through the Bluetooth page to experience full TUIO functionality."/>
                    <LineBreak/><LineBreak/>

                    <Run Text="ENJOY!" FontWeight="Bold" Foreground="#FFD4AF37"/>
                </TextBlock>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>