<UserControl x:Class="GestureGUI.Pages.Page1"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#1E1B4B">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        
        <StackPanel Grid.Row="0" Margin="20">
            <TextBlock Text="TUIO Interaction"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock x:Name="SelectedUserText"
                       Text="User: No user selected"
                       FontSize="16"
                       Foreground="#C4B5FD"
                       Margin="0,8,0,0"/>

            <TextBlock x:Name="SelectedTypeText"
                       Text="Type: -"
                       FontSize="16"
                       Foreground="#FDE68A"
                       Margin="0,4,0,0"/>
            <TextBlock x:Name="WelcomeText"
                       Text=""
                       FontSize="18"
                       FontWeight="SemiBold"
                       Foreground="#FDE68A"
                       Margin="0,10,0,0"
                       TextWrapping="Wrap"/>
        </StackPanel>

       
        <Border Grid.Row="1"
                Margin="20"
                Padding="25"
                Background="#312E81"
                CornerRadius="15">
            <StackPanel>
                <TextBlock Text="Marker Information"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,15"/>

                <TextBlock x:Name="ArtifactText"
                           Text="Artifact: -"
                           FontSize="20"
                           Foreground="White"
                           Margin="0,8,0,0"/>

                <Image x:Name="ArtifactImage"
                       Width="300"
                       Height="220"
                       Stretch="Uniform"
                       Margin="0,15,0,0"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="ArtifactScaleTransform" ScaleX="1" ScaleY="1"/>
                            <RotateTransform x:Name="ArtifactRotateTransform" Angle="0"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                </Image>

                <TextBlock x:Name="MarkerIdText"
                           Text="Marker ID: -"
                           FontSize="18"
                           Foreground="#BFDBFE"
                           Margin="0,8,0,0"/>

                <TextBlock x:Name="RotationText"
                           Text="Rotation: -"
                           FontSize="18"
                           Foreground="#BFDBFE"
                           Margin="0,8,0,0"/>

                <TextBlock x:Name="StatusValueText"
                           Text="Status: -"
                           FontSize="18"
                           Foreground="#FCA5A5"
                           Margin="0,8,0,0"/>
                <TextBlock x:Name="VolumeText"
                           Text="Volume: 50"
                           FontSize="18"
                           Foreground="#86EFAC"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        
        <Border Grid.Row="2"
                Margin="20"
                Padding="20"
                Background="#0F172A"
                CornerRadius="12">
            <StackPanel>
                <TextBlock Text="System Action"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock x:Name="ActionText"
                           Text="No action yet"
                           FontSize="18"
                           Foreground="#22C55E"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>